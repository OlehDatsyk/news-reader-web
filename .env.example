# Rename this file to ".env" (remove ".example") and fill in your own values.

# Your API key from https://newsapi.org (Sign up for free, then copy the key
# from your account dashboard).
NEWS_API_KEY=your_newsapi_key_here

# Optional: the country code used for the default "top headlines" feed.
# Examples: us, gb, in, ca, au, de, fr
NEWS_API_COUNTRY=us
